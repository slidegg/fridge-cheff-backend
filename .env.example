# Copy this file to .env and fill in your values.
# Run: cp .env.example .env

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=recipeapp
MYSQL_USER=recipeapp
MYSQL_PASSWORD=changeme

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Leave blank to use MockOpenAiVisionService (Development only)
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o

# ── Spoonacular ───────────────────────────────────────────────────────────────
# Leave blank to use MockSpoonacularService (Development only)
SPOONACULAR_API_KEY=

# ── Admin panel ───────────────────────────────────────────────────────────────
ADMIN_PASSWORD=changeme_admin

# ── Free tier limits ──────────────────────────────────────────────────────────
FREE_DAILY_SCAN_LIMIT=1
FREE_DAILY_RECIPE_SEARCH_LIMIT=3
FREE_DAILY_RECIPE_DETAIL_LIMIT=3
MAX_IMAGES_PER_SCAN=4
MAX_IMAGE_UPLOAD_MB=8

# Set to true to bypass all daily limits above (dev/QA convenience).
# Usage is still tracked and visible in the admin panel — just never blocks a request.
# NEVER set to true in production.
FREE_TIER_UNLIMITED=false
