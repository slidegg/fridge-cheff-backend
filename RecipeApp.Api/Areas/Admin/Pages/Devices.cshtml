@page "/admin/devices"
@model DevicesModel
@{
    ViewData["Title"] = "Devices";
}

<h2 class="mb-4">Devices <span class="badge bg-secondary fs-6">@Model.Devices.Count</span></h2>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
            <tr>
                <th>Device ID</th>
                <th>Created</th>
                <th>Last Seen</th>
                <th class="text-end">Scans</th>
                <th class="text-end">Searches</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var d in Model.Devices)
            {
                <tr>
                    <td><code>@d.DeviceId</code></td>
                    <td>@d.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@d.LastSeenAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">@d.ScanCount</td>
                    <td class="text-end">@d.SearchCount</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
