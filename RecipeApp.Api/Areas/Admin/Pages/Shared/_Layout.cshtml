<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — RecipeApp Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f8f9fa; }
        .navbar-brand { font-weight: 700; }
        .nav-link.active { font-weight: 600; }
        main { padding: 2rem 0; }
        .stat-card { border-left: 4px solid #0d6efd; }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/admin">RecipeApp Admin</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" href="/admin">Dashboard</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/devices">Devices</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/scans">Scans</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/api-calls">API Calls</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/usage">Usage</a></li>
            </ul>
            <form method="post" action="/admin/logout">
                <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
            </form>
        </div>
    </div>
</nav>
<main>
    <div class="container-fluid">
        @RenderBody()
    </div>
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
