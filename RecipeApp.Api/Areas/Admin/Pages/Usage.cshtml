@page "/admin/usage"
@model UsageModel
@{
    ViewData["Title"] = "Usage";
}

<h2 class="mb-4">Daily Usage — @Model.Today</h2>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
            <tr>
                <th>Device</th>
                <th>Date</th>
                <th class="text-end">Scans</th>
                <th class="text-end">Searches</th>
                <th class="text-end">Detail Views</th>
                <th>Last Updated</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var u in Model.Counters)
            {
                <tr>
                    <td><small>@u.DeviceId</small></td>
                    <td>@u.DateUtc</td>
                    <td class="text-end">@u.ScansUsed</td>
                    <td class="text-end">@u.RecipeSearchesUsed</td>
                    <td class="text-end">@u.RecipeDetailsUsed</td>
                    <td><small>@u.UpdatedAtUtc.ToString("HH:mm:ss")</small></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
